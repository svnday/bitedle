# Copy to .env.local for local development (all optional locally).

# Neon/Postgres connection string. REQUIRED in production.
# The Vercel + Neon integration sets this automatically on Vercel.
# Locally, leaving it unset falls back to JSON-file storage in data/db.json.
DATABASE_URL=

# Seeds each day's hidden board. REQUIRED in production — any long random
# string (e.g. `openssl rand -hex 32`). Changing it changes all boards, so
# set it once and keep it. Locally, a fixed dev value is used if unset.
BITEDLE_SECRET=

# IANA timezone for the daily reset (when "midnight" happens for everyone).
# Optional; defaults to America/New_York.
BITEDLE_TZ=America/New_York

# Discord Application client ID. Only needed to run Bitedle as a Discord
# Activity (embedded in an iframe at *.discordsays.com) — leave unset for
# normal web play. Safe to expose to the browser (NEXT_PUBLIC_): it's a
# public identifier, not a secret. Get it from the Discord Developer Portal
# after completing the setup in README's "Discord Activity setup" section.
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Discord Application client secret. Only needed for the OAuth "identify"
# flow that links a player's real Discord avatar to the leaderboard — leave
# unset for normal web play or if you don't want Discord avatars. Get it
# from the Developer Portal → OAuth2 tab → Client Secret.
# This is a REAL secret: never expose to the browser, never prefix
# NEXT_PUBLIC_, never commit it.
DISCORD_CLIENT_SECRET=

# Discord Application public key. REQUIRED for the /play and /share slash
# commands to work (src/app/api/discord/interactions/route.ts) — Discord
# signs every request to this endpoint, and this key is used to verify that
# signature. Not a secret (Discord itself publishes it), but it must be
# correct or the Developer Portal will refuse to save the Interactions
# Endpoint URL. Get it from the Developer Portal -> General Information ->
# Public Key.
DISCORD_PUBLIC_KEY=
